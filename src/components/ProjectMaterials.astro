---
import type { ProjectEntry, StageEntry } from '../lib/content';
import { groupProjectMaterials } from '../lib/content';

interface Props {
  project: ProjectEntry;
  stages: StageEntry[];
}

const { project, stages } = Astro.props;
const groups = groupProjectMaterials(project.data.materials, stages);

if (groups.length === 0) return null;
---

<section class="mb-10">
  <h2 class="mb-2 text-2xl font-bold text-wp-text">Project Materials</h2>
  <p class="mb-5 max-w-3xl text-sm text-wp-muted">
    Artifacts and documents produced during the product lifecycle, grouped by SDLC stage.
  </p>

  <div class="overflow-hidden rounded-xl border border-wp-border bg-wp-surface">
    {
      groups.map((group, groupIndex) => (
        <div class:list={[groupIndex > 0 && 'border-t border-wp-border']}>
          <div class="flex items-center gap-2 bg-wp-bg/60 px-4 py-2.5">
            <span class="font-mono text-xs text-wp-accent">{group.stage.data.order}</span>
            <span class="text-xs font-semibold uppercase tracking-wide text-wp-text">
              {group.stage.data.title}
            </span>
            <span class="hidden text-xs text-wp-muted sm:inline">— {group.items.length} item{group.items.length === 1 ? '' : 's'}</span>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full min-w-[320px] text-left text-sm">
              <thead class="border-b border-wp-border/80 text-xs uppercase tracking-wide text-wp-muted">
                <tr>
                  <th class="w-[38%] px-4 py-2 font-medium">Material</th>
                  <th class="px-4 py-2 font-medium">Comment</th>
                </tr>
              </thead>
              <tbody>
                {group.items.map((item, itemIndex) => (
                  <tr
                    class:list={[
                      itemIndex < group.items.length - 1 && 'border-b border-wp-border/50'
                    ]}
                  >
                    <td class="align-top px-4 py-2.5">
                      <a
                        href={item.url}
                        target="_blank"
                        rel="noreferrer"
                        class="font-medium text-wp-accent hover:underline"
                      >
                        {item.title}
                      </a>
                    </td>
                    <td class="align-top px-4 py-2.5 text-wp-muted">
                      {item.summary || '—'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      ))
    }
  </div>
</section>
