---
import type { ProjectEntry, StageEntry } from '../lib/content';
import { getStageIndex } from '../lib/content';

interface Props {
  project: ProjectEntry;
  stages: StageEntry[];
}

const { project, stages } = Astro.props;
const currentIndex = getStageIndex(project.data.stage, stages);
---

<div class="overflow-x-auto pb-1 md:overflow-visible" aria-label="SDLC progress">
  <ol class="flex w-full min-w-max items-start justify-between gap-1 md:min-w-0">
    {stages.map((stage, index) => {
      const state =
        index < currentIndex ? 'done' : index === currentIndex ? 'current' : 'future';
      const symbol = state === 'done' ? '✓' : state === 'current' ? '●' : '○';
      const color =
        state === 'done'
          ? 'text-wp-accent'
          : state === 'current'
            ? 'text-wp-accent font-semibold'
            : 'text-wp-muted';

      return (
        <li
          class={`flex min-w-[4.5rem] flex-1 flex-col items-center px-1 text-center sm:min-w-0 ${color}`}
          title={stage.data.title}
        >
          <span class="text-lg leading-none" aria-hidden="true">
            {symbol}
          </span>
          <span class="mt-1 hidden text-[10px] sm:block md:text-xs">{stage.data.title}</span>
        </li>
      );
    })}
  </ol>
</div>
