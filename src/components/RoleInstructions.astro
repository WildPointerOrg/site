---
import type { RoleEntry } from '../lib/content';

interface Props {
  role: RoleEntry;
}

const { role } = Astro.props;
const items = [...(role.data.instructions ?? [])].sort((a, b) => a.order - b.order);

if (items.length === 0) return null;
---

<section class="mb-10 w-full">
  <div class="overflow-hidden rounded-xl border border-wp-accent/25 bg-wp-accent/5">
    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1 border-b border-wp-accent/20 bg-wp-surface/80 px-4 py-3">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-wp-text">
        Instructions &amp; Documentation
      </h2>
      <span class="text-xs text-wp-muted">{items.length} resource{items.length === 1 ? '' : 's'}</span>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full min-w-[320px] text-left text-sm">
        <thead class="border-b border-wp-border/80 bg-wp-surface/50 text-xs uppercase tracking-wide text-wp-muted">
          <tr>
            <th class="w-[42%] px-4 py-2 font-medium">Document</th>
            <th class="px-4 py-2 font-medium">Comment</th>
          </tr>
        </thead>
        <tbody class="bg-wp-surface/40">
          {
            items.map((item, index) => (
              <tr class:list={[index < items.length - 1 && 'border-b border-wp-border/50']}>
                <td class="align-top px-4 py-2.5">
                  <div class="flex flex-wrap items-center gap-2">
                    {
                      item.docId && (
                        <span class="rounded border border-wp-border px-1.5 py-0.5 font-mono text-[10px] text-wp-muted">
                          {item.docId}
                        </span>
                      )
                    }
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noreferrer"
                      class="font-medium text-wp-accent hover:underline"
                    >
                      {item.title}
                    </a>
                  </div>
                </td>
                <td class="align-top px-4 py-2.5 text-wp-muted">{item.summary || '—'}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
