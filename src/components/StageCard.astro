---
import type { StageEntry } from '../lib/content';
import { stageSlug } from '../lib/content';
import { withBase } from '../lib/paths';

interface Props {
  stage: StageEntry;
  compact?: boolean;
}

const { stage, compact = false } = Astro.props;
const { title, shortDescription, mainOutput } = stage.data;
const stageHref = withBase(`sdlc/${stageSlug(stage)}/`);
---

<article class="rounded-lg border border-wp-border bg-wp-surface p-5 transition hover:border-wp-accent/40">
  <h3 class="mb-2 text-lg font-semibold text-wp-text">
    <a href={stageHref} class="hover:text-wp-accent">{title}</a>
  </h3>
  <p class="text-sm leading-relaxed text-wp-muted">{shortDescription}</p>
  {!compact && (
    <p class="mt-3 text-xs text-wp-muted">
      <span class="font-medium text-wp-text">Main output:</span> {mainOutput}
    </p>
  )}
  <a href={stageHref} class="mt-4 inline-block text-sm font-medium text-wp-accent hover:underline">
    Learn more →
  </a>
</article>
