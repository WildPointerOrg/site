---
import Layout from '../../layouts/Layout.astro';
import DocumentCard from '../../components/DocumentCard.astro';
import { getAllDocuments } from '../../lib/content';

const documents = await getAllDocuments();
const categories = ['ENT', 'PRC', 'INS'] as const;
---

<Layout title="Documents — WildPointer" description="WildPointer organizational, process, and instruction documents.">
  <div class="page-container py-12 md:py-16">
    <h1 class="section-title">Documents</h1>
    <p class="section-lead">Registry of governing, process, and instruction documents.</p>

    {
      categories.map((category) => {
        const items = documents.filter((d) => d.data.category === category);
        if (items.length === 0) return null;
        return (
          <section class="mb-10">
            <h2 class="mb-4 text-xl font-semibold text-wp-text">{category}</h2>
            <div class="grid gap-4 md:grid-cols-2">
              {items.map((doc) => <DocumentCard document={doc} />)}
            </div>
          </section>
        );
      })
    }
  </div>
</Layout>
