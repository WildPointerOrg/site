---
import Layout from '../../layouts/Layout.astro';
import CompanyDocumentsTable from '../../components/CompanyDocumentsTable.astro';
import { getAllDocuments } from '../../lib/content';
import { SITE } from '../../config/site';

const documents = await getAllDocuments();
---

<Layout
  title="Docs — WildPointer"
  description="WildPointer organizational, process, and instruction documents."
>
  <div class="page-container py-12 md:py-16">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="section-title mb-2">Docs</h1>
        <p class="section-lead mb-0">
          Company documents — governance, processes, and role instructions.
        </p>
      </div>
      <a
        href={SITE.documentsFolder}
        target="_blank"
        rel="noreferrer"
        class="btn-primary shrink-0"
      >
        Open Documents Folder
      </a>
    </div>

    <CompanyDocumentsTable documents={documents} />
  </div>
</Layout>
