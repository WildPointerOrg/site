---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import StageNavigator from '../components/StageNavigator.astro';
import RoleCard from '../components/RoleCard.astro';
import JoinCTA from '../components/JoinCTA.astro';
import { SITE } from '../config/site';
import { withBase } from '../lib/paths';
import {
  getAllProjects,
  getFeaturedProjects,
  getAllStages,
  getAllRoles,
  roleSlug
} from '../lib/content';

const [projects, featuredProjects, stages, roles] = await Promise.all([
  getAllProjects(),
  getFeaturedProjects(6),
  getAllStages(),
  getAllRoles()
]);

const homeRoleSlugs = ['product-lead', 'coordinator', 'community-steward', 'maintainer'];
const homeRoles = homeRoleSlugs
  .map((slug) => roles.find((r) => roleSlug(r) === slug))
  .filter((r): r is NonNullable<typeof r> => Boolean(r));

const activeProjects = projects.filter((p) => p.data.status === 'active');
const stats = {
  projects: projects.length,
  members: SITE.memberCount ?? '—',
  squads: activeProjects.length
};
---

<Layout title={SITE.title} description={SITE.description}>
  <section class="page-container border-b border-wp-border py-16 md:py-24">
    <h1 class="mb-6 max-w-4xl text-4xl font-bold tracking-tight text-wp-text md:text-6xl">
      Build Real Products Together
    </h1>
    <p class="mb-8 max-w-3xl text-lg leading-relaxed text-wp-muted md:text-xl">
      WildPointer is an open volunteer community where engineers, product managers, designers,
      researchers and enthusiasts create real open-source products together.
    </p>
    <div class="mb-10 flex flex-wrap gap-3">
      <a href={withBase('join/')} class="btn-primary">JOIN THE COMMUNITY</a>
      <a href={withBase('projects/')} class="btn-secondary">VIEW PROJECTS</a>
    </div>
    <dl class="grid max-w-xl grid-cols-3 gap-4 rounded-lg border border-wp-border bg-wp-surface p-5">
      <div>
        <dt class="text-xs uppercase tracking-wide text-wp-muted">Projects</dt>
        <dd class="text-2xl font-bold text-wp-text">{stats.projects}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-wp-muted">Members</dt>
        <dd class="text-2xl font-bold text-wp-text">{stats.members}</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-wp-muted">Active Squads</dt>
        <dd class="text-2xl font-bold text-wp-text">{stats.squads}</dd>
      </div>
    </dl>
  </section>

  <section class="page-container py-16 md:py-20">
    <h2 class="section-title">Why Join</h2>
    <div class="grid gap-6 md:grid-cols-3">
      <article class="rounded-lg border border-wp-border bg-wp-surface p-6">
        <h3 class="mb-3 text-xl font-semibold text-wp-accent">Learn</h3>
        <p class="text-sm leading-relaxed text-wp-muted">
          Gain real team experience. Work with actual projects, discussions, reviews and deliveries.
        </p>
      </article>
      <article class="rounded-lg border border-wp-border bg-wp-surface p-6">
        <h3 class="mb-3 text-xl font-semibold text-wp-accent">Build</h3>
        <p class="text-sm leading-relaxed text-wp-muted">
          Create products that solve real problems. Not exercises. Not toy projects.
        </p>
      </article>
      <article class="rounded-lg border border-wp-border bg-wp-surface p-6">
        <h3 class="mb-3 text-xl font-semibold text-wp-accent">Grow</h3>
        <p class="text-sm leading-relaxed text-wp-muted">
          Expand your network, portfolio and practical skills.
        </p>
      </article>
    </div>
    <p class="mt-8 text-center text-wp-muted">
      No subscriptions. No courses. No hidden payments.<br />
      <span class="text-wp-text">Only real projects and real collaboration.</span>
    </p>
  </section>

  <section class="page-container py-16 md:py-20">
    <h2 class="section-title">What We Build</h2>
    <p class="section-lead">
      WildPointer develops open-source software products and technology solutions.
    </p>
    <ul class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
      {
        [
          'AI applications',
          'automation systems',
          'developer tools',
          'productivity software',
          'community products',
          'infrastructure solutions'
        ].map((item) => (
          <li class="rounded border border-wp-border bg-wp-surface px-4 py-3 text-sm text-wp-muted">
            {item}
          </li>
        ))
      }
    </ul>
    <p class="mt-6 text-sm text-wp-muted">All results remain open-source.</p>
  </section>

  <section class="page-container py-16 md:py-20">
    <h2 class="section-title">Product Lifecycle</h2>
    <p class="section-lead">
      WildPointer uses a transparent lifecycle. Contributors can join at any stage.
    </p>
    <StageNavigator stages={stages} />
    <p class="mt-6">
      <a href={withBase('sdlc/')} class="text-sm font-medium text-wp-accent hover:underline">
        Explore full SDLC →
      </a>
    </p>
  </section>

  <section class="page-container py-16 md:py-20">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <h2 class="section-title mb-0">Active Projects</h2>
      <a href={withBase('projects/')} class="text-sm font-medium text-wp-accent hover:underline">
        View All Projects
      </a>
    </div>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="page-container py-16 md:py-20">
    <h2 class="section-title">How You Can Contribute</h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {homeRoles.map((role) => <RoleCard role={role} />)}
    </div>
    <p class="mt-6">
      <a href={withBase('roles/')} class="text-sm font-medium text-wp-accent hover:underline">
        View all roles →
      </a>
    </p>
  </section>

  <section class="page-container pb-20">
    <JoinCTA />
  </section>
</Layout>
