---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../config/site';
import { withBase } from '../lib/paths';
---

<Layout title="Join WildPointer" description="Start contributing today. No permission required.">
  <div class="page-container py-12 md:py-16">
    <header class="mb-12 max-w-3xl">
      <h1 class="section-title">Join WildPointer</h1>
      <p class="text-xl text-wp-muted">Start contributing today. No permission required.</p>
    </header>

    <section class="mb-14">
      <h2 class="mb-6 text-2xl font-bold text-wp-text">Ways To Join</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <article class="rounded-lg border border-wp-border bg-wp-surface p-5">
          <h3 class="mb-1 font-semibold text-wp-text">Telegram</h3>
          <p class="mb-4 text-sm text-wp-muted">Community Chat</p>
          <a href={SITE.telegram} target="_blank" rel="noreferrer" class="btn-primary">
            Open Telegram
          </a>
        </article>
        <article class="rounded-lg border border-wp-border bg-wp-surface p-5">
          <h3 class="mb-1 font-semibold text-wp-text">GitHub</h3>
          <p class="mb-4 text-sm text-wp-muted">Organization Profile</p>
          <a href={SITE.github} target="_blank" rel="noreferrer" class="btn-primary">
            Open GitHub
          </a>
        </article>
        <article class="rounded-lg border border-wp-border bg-wp-surface p-5">
          <h3 class="mb-1 font-semibold text-wp-text">LinkedIn</h3>
          <p class="mb-4 text-sm text-wp-muted">Company page and community updates</p>
          <a href={SITE.linkedin} target="_blank" rel="noreferrer" class="btn-primary">
            Open LinkedIn
          </a>
        </article>
        <article class="rounded-lg border border-wp-border bg-wp-surface p-5">
          <h3 class="mb-1 font-semibold text-wp-text">Email</h3>
          <p class="mb-4 text-sm text-wp-muted">Reach the community team</p>
          <a href={SITE.email} class="btn-primary">
            Send Email
          </a>
        </article>
        <article class="rounded-lg border border-wp-border bg-wp-surface p-5">
          <h3 class="mb-1 font-semibold text-wp-text">Google Form</h3>
          <p class="mb-4 text-sm text-wp-muted">Contributor Application</p>
          {
            SITE.contributorFormUrl ? (
              <a href={SITE.contributorFormUrl} target="_blank" rel="noreferrer" class="btn-primary">
                Open Form
              </a>
            ) : (
              <span class="text-sm text-wp-muted">Form URL coming soon.</span>
            )
          }
        </article>
      </div>
    </section>

    <section class="mb-8">
      <h2 class="mb-6 text-2xl font-bold text-wp-text">FAQ</h2>
      <dl class="space-y-6">
        <div>
          <dt class="mb-1 font-semibold text-wp-text">Do I need experience?</dt>
          <dd class="text-wp-muted">No.</dd>
        </div>
        <div>
          <dt class="mb-1 font-semibold text-wp-text">Do I need to commit full-time?</dt>
          <dd class="text-wp-muted">No.</dd>
        </div>
        <div>
          <dt class="mb-1 font-semibold text-wp-text">Can I leave anytime?</dt>
          <dd class="text-wp-muted">Yes.</dd>
        </div>
        <div>
          <dt class="mb-1 font-semibold text-wp-text">Is participation paid?</dt>
          <dd class="text-wp-muted">Participation is volunteer-based.</dd>
        </div>
      </dl>
    </section>

    <p>
      <a href={withBase('projects/')} class="text-sm font-medium text-wp-accent hover:underline">
        Browse active projects →
      </a>
    </p>
  </div>
</Layout>
