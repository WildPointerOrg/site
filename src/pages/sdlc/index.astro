---
import Layout from '../../layouts/Layout.astro';
import StageCard from '../../components/StageCard.astro';
import { getAllStages } from '../../lib/content';

const stages = await getAllStages();
---

<Layout
  title="Product Development Lifecycle — WildPointer"
  description="WildPointer uses a transparent lifecycle that allows contributors to join projects at any stage."
>
  <div class="page-container py-12 md:py-16">
    <h1 class="section-title">Product Development Lifecycle</h1>
    <p class="section-lead">
      WildPointer uses a transparent lifecycle that allows contributors to join projects at any stage.
    </p>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {stages.map((stage) => <StageCard stage={stage} />)}
    </div>
  </div>
</Layout>
